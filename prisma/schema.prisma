generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  name            String?
  emailVerified   Boolean    @default(false)
  verifyCode      String?
  verifyExpires   DateTime?
  createdAt       DateTime   @default(now())
  businesses      Business[]
}

model Business {
  id          String   @id @default(cuid())
  userId      String
  name        String
  slug        String   @unique
  description String?
  website     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  reviews     Review[]
}

model Review {
  id         String   @id @default(cuid())
  businessId String
  author     String
  email      String?
  rating     Int
  text       String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
}
